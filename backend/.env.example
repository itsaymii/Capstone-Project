# Copy this file to backend/.env and fill in your real Gmail values.
# For Gmail, use an App Password (not your normal Gmail password).

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=yourgmailaddress@gmail.com
EMAIL_HOST_PASSWORD=your_16_character_app_password
DEFAULT_FROM_EMAIL=DRMS OTP <yourgmailaddress@gmail.com>

# OTP email customization
OTP_EMAIL_SUBJECT=Your DRMS OTP Code
OTP_EMAIL_BODY_TEMPLATE=Hello,\n\nYour OTP code for {action_label} is: {otp_code}\n\nThis code expires in {expiry_minutes} minutes.\n\nIf you did not request this, you can ignore this email.
