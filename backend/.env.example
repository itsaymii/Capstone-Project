# Copy this file to backend/.env and fill in your real Gmail values.
# For Gmail, use an App Password (not your normal Gmail password).

# ============================================
# Django Core Settings
# ============================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# Database Settings
# ============================================
# For PostgreSQL + PostGIS (Production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=drms_db
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# For SQLite + SpatiaLite (Development - simpler)
# DB_ENGINE=django.contrib.gis.db.backends.spatialite
# DB_NAME=db.sqlite3

# ============================================
# GeoDjango Library Paths (Windows - OSGeo4W)
# ============================================
# Find your actual DLL version numbers in OSGeo4W\bin\ folder
# If using Express Install, paths might be different

GDAL_LIBRARY_PATH=C:\\OSGeo4W\\bin\\gdal306.dll
GEOS_LIBRARY_PATH=C:\\OSGeo4W\\bin\\geos_c.dll
PROJ_LIBRARY_PATH=C:\\OSGeo4W\\bin\\proj.dll

# Alternative: Leave empty to auto-detect from System PATH
# GDAL_LIBRARY_PATH=
# GEOS_LIBRARY_PATH=
# PROJ_LIBRARY_PATH=

# ============================================
# Email Settings (for OTP)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=yourgmailaddress@gmail.com
EMAIL_HOST_PASSWORD=your_16_character_app_password
DEFAULT_FROM_EMAIL=DRMS OTP <yourgmailaddress@gmail.com>

# OTP email customization
OTP_EMAIL_SUBJECT=Your DRMS OTP Code
OTP_EMAIL_BODY_TEMPLATE=Hello,\n\nYour OTP code for {action_label} is: {otp_code}\n\nThis code expires in {expiry_minutes} minutes.\n\nIf you did not request this, you can ignore this email.